-- FlareX V3 by Fares - Steal a Brainrot (ESP + Auto Grab + Draggable)
local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local ProximityPromptService = game:GetService("ProximityPromptService")

local ENABLED = false
local AUTO_TP_BASE = true
local AUTO_GRAB = true
local ESP_ENABLED = true

local connection = nil
local TP_SPEED = 190
local espObjects = {}

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FlareX"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

-- Main Button
local mainButton = Instance.new("TextButton")
mainButton.Size = UDim2.new(0, 85, 0, 85)
mainButton.Position = UDim2.new(0, 15, 1, -110)
mainButton.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
mainButton.Text = "FLAREX"
mainButton.TextColor3 = Color3.fromRGB(0, 255, 200)
mainButton.TextScaled = true
mainButton.Font = Enum.Font.GothamBold
mainButton.Parent = screenGui

Instance.new("UICorner", mainButton).CornerRadius = UDim.new(1, 0)
Instance.new("UIStroke", mainButton).Thickness = 4
Instance.new("UIStroke", mainButton).Color = Color3.fromRGB(0, 255, 200)

-- Menu Draggable
local menu = Instance.new("Frame")
menu.Size = UDim2.new(0, 280, 0, 340)
menu.Position = UDim2.new(0.5, -140, 0.5, -170)
menu.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
menu.Visible = false
menu.Parent = screenGui
Instance.new("UICorner", menu).CornerRadius = UDim.new(0, 16)

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,45)
title.BackgroundTransparency = 1
title.Text = "FLAREX MENU"
title.TextColor3 = Color3.fromRGB(0, 255, 200)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = menu

-- Rendre le menu draggable
local dragging = false
local dragStart, startPos
title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = menu.Position
    end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        menu.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
title.InputEnded:Connect(function() dragging = false end)

-- Boutons
local function createBtn(text, y, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9,0,0,48)
    btn.Position = UDim2.new(0.05,0,0,y)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = menu
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,10)
    return btn
end

local tpBtn = createBtn("Semi TP : OFF", 55, Color3.fromRGB(30,30,30))
local grabBtn = createBtn("Auto Grab : ON", 110, Color3.fromRGB(0,170,0))
local baseBtn = createBtn("Auto TP Base : ON", 165, Color3.fromRGB(0,170,0))
local espBtn = createBtn("ESP Brainrot : ON", 220, Color3.fromRGB(0,170,0))
local closeBtn = createBtn("Fermer FlareX", 275, Color3.fromRGB(150,0,0))

local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
local myBase = nil

local function findMyBase()
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name:lower():find("base") or v.Name:lower():find("plot") then
            local part = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChildWhichIsA("BasePart")
            if part then return part end
        end
    end
    return nil
end

local function createESP(model)
    if espObjects[model] then return end
    local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head")
    if not hrp then return end

    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = hrp
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = playerGui

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.fromRGB(255, 100, 100)
    text.TextStrokeTransparency = 0
    text.TextScaled = true
    text.Font = Enum.Font.GothamBold
    text.Parent = billboard

    espObjects[model] = billboard

    spawn(function()
        while billboard.Parent do
            local name = model.Name
            local value = "??"
            -- Essaie de trouver une valeur (souvent dans un NumberValue ou StringValue)
            local val = model:FindFirstChild("Value") or model:FindFirstChild("Cash") or model:FindFirstChildWhichIsA("NumberValue")
            if val then value = val.Value end
            text.Text = name .. "\nValue: " .. tostring(value)
            task.wait(0.5)
        end
    end)
end

local function updateESP()
    for _, model in pairs(workspace:GetDescendants()) do
        if model:IsA("Model") and model:FindFirstChild("Humanoid") and model ~= player.Character then
            createESP(model)
        end
    end
end

local function getNearestBrainrot()
    local closest, shortest = nil, math.huge
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= player.Character then
            local hrp = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Head")
            if hrp then
                local dist = (root.Position - hrp.Position).Magnitude
                if dist < shortest and dist < 600 then
                    shortest = dist
                    closest = hrp
                end
            end
        end
    end
    return closest
end

local function semiTP(target)
    if not target or not root then return end
    local dist = (root.Position - target.Position).Magnitude
    TweenService:Create(root, TweenInfo.new(dist/TP_SPEED, Enum.EasingStyle.Linear), {
        CFrame = target.CFrame + Vector3.new(0,7,0)
    }):Play()
end

local function tpToBase()
    if not myBase then myBase = findMyBase() end
    if myBase and root then
        root.CFrame = myBase.CFrame + Vector3.new(0, 12, 0)
    end
end

-- Connections
ProximityPromptService.PromptTriggered:Connect(function(prompt)
    if prompt.ActionText:lower():find("steal") or prompt.ActionText:lower():find("take") then
        task.wait(0.65)
        if AUTO_TP_BASE then tpToBase() end
    end
end)

-- Toggle Buttons
tpBtn.MouseButton1Click:Connect(function()
    ENABLED = not ENABLED
    tpBtn.Text = "Semi TP : " .. (ENABLED and "ON ✅" or "OFF ❌")
    tpBtn.BackgroundColor3 = ENABLED and Color3.fromRGB(0,170,0) or Color3.fromRGB(30,30,30)
    
    if ENABLED then
        connection = RunService.Heartbeat:Connect(function()
            if not ENABLED or not root then return end
            local target = getNearestBrainrot()
            if target then semiTP(target) end
        end)
    else
        if connection then connection:Disconnect() end
    end
end)

grabBtn.MouseButton1Click:Connect(function()
    AUTO_GRAB = not AUTO_GRAB
    grabBtn.Text = "Auto Grab : " .. (AUTO_GRAB and "ON ✅" or "OFF ❌")
    grabBtn.BackgroundColor3 = AUTO_GRAB and Color3.fromRGB(0,170,0) or Color3.fromRGB(30,30,30)
end)

baseBtn.MouseButton1Click:Connect(function()
    AUTO_TP_BASE = not AUTO_TP_BASE
    baseBtn.Text = "Auto TP Base : " .. (AUTO_TP_BASE and "ON ✅" or "OFF ❌")
    baseBtn.BackgroundColor3 = AUTO_TP_BASE and Color3.fromRGB(0,170,0) or Color3.fromRGB(30,30,30)
end)

espBtn.MouseButton1Click:Connect(function()
    ESP_ENABLED = not ESP_ENABLED
    espBtn.Text = "ESP Brainrot : " .. (ESP_ENABLED and "ON ✅" or "OFF ❌")
    espBtn.BackgroundColor3 = ESP_ENABLED and Color3.fromRGB(0,170,0) or Color3.fromRGB(30,30,30)
end)

closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
    if connection then connection:Disconnect() end
    for _, v in pairs(espObjects) do v:Destroy() end
end)

-- Loop ESP
RunService.Heartbeat:Connect(function()
    if ESP_ENABLED then
        updateESP()
    end
end)

player.CharacterAdded:Connect(function(char)
    root = char:WaitForChild("HumanoidRootPart")
end)

print("✅ FlareX V3 chargé ! (ESP Brainrot + Menu déplaçable)")
